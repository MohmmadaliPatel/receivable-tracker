// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String    // Hashed password
  name          String?
  email         String?   @unique
  role          String    @default("user") // "admin" | "user"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  emailConfigs  EmailConfig[]
  senders       Sender[]
  forwarders    Forwarder[]

  @@map("users")
}

model EmailConfig {
  id              String   @id @default(cuid())
  name            String   // Configuration name (e.g., "Primary", "Backup")
  type            String   @default("graph") // "graph" or "smtp" (only graph implemented)
  msTenantId      String   // MS_TENANT_ID
  msClientId      String   // MS_CLIENT_ID
  msClientSecret  String   // MS_CLIENT_SECRET
  fromEmail       String   // FROM_EMAIL
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailTrackings  EmailTracking[]
  isActive        Boolean  @default(true)
  cronEnabled     Boolean  @default(false) // Enable automatic fetching
  cronIntervalMinutes Int  @default(10) // Interval in minutes (e.g., 10 = every 10 minutes)
  reminderEnabled Boolean  @default(false) // Enable reminder emails
  reminderDurationHours Int @default(24) // Send reminder if no reply within this duration
  reminderDurationUnit String @default("hours") // "hours" or "minutes"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_configs")
}

model Email {
  id          String   @id @default(cuid())
  to          String   // Recipient email
  subject     String?
  body        String?
  htmlBody    String?
  sentAt      DateTime @default(now())
  status      String   @default("sent") // sent, failed, pending
  errorMessage String?
  emailConfigId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("emails")
}

model Sender {
  id            String   @id @default(cuid())
  email         String   @unique // Email address to track
  name          String?  // Optional name
  isActive      Boolean  @default(true)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailTrackings EmailTracking[]
  forwardingRules ForwardingRule[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("senders")
}

model EmailTracking {
  id              String   @id @default(cuid())
  senderId        String
  sender          Sender   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Original email details
  originalMessageId  String   @unique // Graph API message ID
  originalSubject    String?
  originalBody       String?
  originalHtmlBody   String?
  originalFromEmail  String
  originalFromName   String?
  originalReceivedAt DateTime
  
  // Forwarding details
  isForwarded     Boolean  @default(false)
  forwardedTo     String?  // Comma-separated list of emails
  forwardedAt     DateTime?
  forwardMessageId String? // Graph API message ID of forwarded email
  autoForwarded   Boolean  @default(false) // Whether it was auto-forwarded via rule
  
  // Reply tracking
  hasReplies      Boolean  @default(false)
  lastReplyAt     DateTime?
  replyCount      Int      @default(0)
  
  // Reminder tracking
  reminderSent    Boolean  @default(false) // Whether reminder email has been sent
  reminderSentAt  DateTime? // When reminder was sent
  
  // Attachments
  hasAttachments  Boolean  @default(false)
  attachmentIds   String?  // JSON array of attachment IDs
  
  // Status
  status          String   @default("received") // received, forwarded, replied, error, reminder_sent
  errorMessage    String?
  
  userId          String
  emailConfigId   String?
  emailConfig     EmailConfig? @relation(fields: [emailConfigId], references: [id], onDelete: SetNull)
  replies         EmailReply[] // Replies to this forwarded email
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_trackings")
}

model EmailReply {
  id              String   @id @default(cuid())
  emailTrackingId String
  emailTracking   EmailTracking @relation(fields: [emailTrackingId], references: [id], onDelete: Cascade)
  
  // Reply message details
  messageId       String   @unique // Graph API message ID
  subject         String?
  body            String?
  htmlBody        String?
  bodyPreview     String?
  fromEmail       String
  fromName        String?
  receivedAt      DateTime
  
  // Attachments
  hasAttachments  Boolean  @default(false)
  attachmentIds   String?  // JSON array of attachment info: [{id, name, contentType, size}]
  
  userId          String
  emailConfigId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_replies")
}

model ForwardingRule {
  id              String   @id @default(cuid())
  senderId        String
  sender          Sender   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Forward to emails (comma-separated or JSON array)
  forwardToEmails String   // Comma-separated list of email addresses
  
  // Subject filter (optional - partial match)
  subjectFilter   String?  // If provided, only forward emails whose subject contains this text (case-insensitive)
  
  // Configuration
  isActive        Boolean  @default(true)
  autoForward     Boolean  @default(true) // Automatically forward when email received
  
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("forwarding_rules")
}

model Forwarder {
  id            String   @id @default(cuid())
  email         String   // Email address to send from/to
  name          String?  // Optional name/description
  subject       String?  // Default subject template
  isActive      Boolean  @default(true)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("forwarders")
}

model ConfirmationRecord {
  id                   String    @id @default(cuid())
  entityName           String
  category             String    // "Bank Balances and FDs" | "Borrowings" | "Trade Receivables" | "Trade Payables" | "Other Receivables" | "Other Payables"
  bankName             String?   // Bank Name / Confirming Party
  accountNumber        String?   // Bank/Loan Account Number (editable for Bank Balances/FDs and Borrowings)
  custId               String?   // Customer ID (editable for Bank Balances/FDs and Borrowings)
  emailTo              String    // Comma-separated email TO addresses
  emailCc              String?   // Comma-separated email CC addresses

  // Status tracking
  status               String    @default("not_sent") // not_sent | sent | followup_sent | response_received

  // Sent email details
  sentAt               DateTime?
  sentMessageId        String?   // Graph API message ID of sent confirmation
  sentEmailFilePath    String?   // Local file path of saved sent email HTML

  // Follow-up details (latest follow-up — kept for backward compat)
  followupSentAt       DateTime?
  followupMessageId    String?
  followupEmailFilePath String?

  // Follow-up history (all follow-ups, newest last)
  followupCount        Int       @default(0)
  followupsJson        String?   // JSON: [{sentAt, messageId, filePath, subject}]

  // Response details (first/latest response — kept for quick access)
  responseReceivedAt      DateTime?
  responseMessageId       String?
  responseSubject         String?
  responseBody            String?
  responseHtmlBody        String?
  responseFromEmail       String?
  responseFromName        String?
  responseEmailFilePath   String?  // Local file path of saved response HTML
  responseHasAttachments  Boolean  @default(false)
  responseAttachmentsJson String?  // JSON array: [{id, name, contentType, size}]

  // All responses (supports multiple replies in the same thread)
  responsesJson           String?  // JSON array: [{receivedAt, messageId, subject, fromEmail, fromName, htmlBody, body, filePath, hasAttachments, attachmentsJson}]

  // Attachment (Authority Letter)
  attachmentPath       String?   // Server path to uploaded attachment
  attachmentName       String?   // Original filename

  // Folder paths for navigating without app
  emailsSentFolderPath    String?  // Relative folder path: emails/{Entity}/{Category}/Emails Sent/
  responsesFolderPath     String?  // Relative folder path: emails/{Entity}/{Category}/Responses Received/

  // Query/Remarks
  remarks              String?

  userId               String
  emailConfigId        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("confirmation_records")
}

model AppSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  autoReplyCheck            Boolean  @default(true)   // Automatically check for replies on cron
  replyCheckIntervalMinutes Int      @default(30)      // How often to check for replies
  emailSaveBasePath         String   @default("emails") // Base folder path for saving emails
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("app_settings")
}
