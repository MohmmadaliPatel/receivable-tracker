// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String    // Hashed password
  name          String?
  email         String?   @unique
  role          String    @default("user") // "admin" | "user"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  emailConfigs  EmailConfig[]
  senders       Sender[]
  forwarders    Forwarder[]
  agingImports          AgingImport[]
  invoiceChases         InvoiceChase[]
  agingLineItems        AgingLineItem[]
  agingAttachmentRules            AgingAttachmentRule[]
  agingImportCustomerAttachments  AgingImportCustomerAttachment[]
  customerEmailEntries  CustomerEmailEntry[]
  excludedCustomers     ExcludedCustomer[]

  @@map("users")
}

model EmailConfig {
  id              String   @id @default(cuid())
  name            String   // Configuration name (e.g., "Primary", "Backup")
  type            String   @default("graph") // "graph" or "smtp" (only graph implemented)
  msTenantId      String   // MS_TENANT_ID
  msClientId      String   // MS_CLIENT_ID
  msClientSecret  String   // MS_CLIENT_SECRET
  fromEmail       String   // FROM_EMAIL
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailTrackings  EmailTracking[]
  sentEmails      Email[]
  isActive        Boolean  @default(true)
  cronEnabled     Boolean  @default(false) // Enable automatic fetching
  cronIntervalMinutes Int  @default(10) // Interval in minutes (e.g., 10 = every 10 minutes)
  reminderEnabled Boolean  @default(false) // Enable reminder emails
  reminderDurationHours Int @default(24) // Send reminder if no reply within this duration
  reminderDurationUnit String @default("hours") // "hours" or "minutes"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_configs")
}

model Email {
  id          String   @id @default(cuid())
  to          String   // Recipient email
  subject     String?
  body        String?
  htmlBody    String?
  sentAt      DateTime @default(now())
  status      String   @default("sent") // sent, failed, pending
  errorMessage String?
  emailConfigId String?
  emailConfig   EmailConfig? @relation(fields: [emailConfigId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("emails")
}

model Sender {
  id            String   @id @default(cuid())
  email         String   @unique // Email address to track
  name          String?  // Optional name
  isActive      Boolean  @default(true)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailTrackings EmailTracking[]
  forwardingRules ForwardingRule[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("senders")
}

model EmailTracking {
  id              String   @id @default(cuid())
  senderId        String
  sender          Sender   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Original email details
  originalMessageId  String   @unique // Graph API message ID
  originalSubject    String?
  originalBody       String?
  originalHtmlBody   String?
  originalFromEmail  String
  originalFromName   String?
  originalReceivedAt DateTime
  
  // Forwarding details
  isForwarded     Boolean  @default(false)
  forwardedTo     String?  // Comma-separated list of emails
  forwardedAt     DateTime?
  forwardMessageId String? // Graph API message ID of forwarded email
  autoForwarded   Boolean  @default(false) // Whether it was auto-forwarded via rule
  
  // Reply tracking
  hasReplies      Boolean  @default(false)
  lastReplyAt     DateTime?
  replyCount      Int      @default(0)
  
  // Reminder tracking
  reminderSent    Boolean  @default(false) // Whether reminder email has been sent
  reminderSentAt  DateTime? // When reminder was sent
  
  // Attachments
  hasAttachments  Boolean  @default(false)
  attachmentIds   String?  // JSON array of attachment IDs
  
  // Status
  status          String   @default("received") // received, forwarded, replied, error, reminder_sent
  errorMessage    String?
  
  userId          String
  emailConfigId   String?
  emailConfig     EmailConfig? @relation(fields: [emailConfigId], references: [id], onDelete: SetNull)
  replies         EmailReply[] // Replies to this forwarded email
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_trackings")
}

model EmailReply {
  id              String   @id @default(cuid())
  emailTrackingId String
  emailTracking   EmailTracking @relation(fields: [emailTrackingId], references: [id], onDelete: Cascade)
  
  // Reply message details
  messageId       String   @unique // Graph API message ID
  subject         String?
  body            String?
  htmlBody        String?
  bodyPreview     String?
  fromEmail       String
  fromName        String?
  receivedAt      DateTime
  
  // Attachments
  hasAttachments  Boolean  @default(false)
  attachmentIds   String?  // JSON array of attachment info: [{id, name, contentType, size}]
  
  userId          String
  emailConfigId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_replies")
}

model ForwardingRule {
  id              String   @id @default(cuid())
  senderId        String
  sender          Sender   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Forward to emails (comma-separated or JSON array)
  forwardToEmails String   // Comma-separated list of email addresses
  
  // Subject filter (optional - partial match)
  subjectFilter   String?  // If provided, only forward emails whose subject contains this text (case-insensitive)
  
  // Configuration
  isActive        Boolean  @default(true)
  autoForward     Boolean  @default(true) // Automatically forward when email received
  
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("forwarding_rules")
}

model Forwarder {
  id            String   @id @default(cuid())
  email         String   // Email address to send from/to
  name          String?  // Optional name/description
  subject       String?  // Default subject template
  isActive      Boolean  @default(true)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("forwarders")
}

model ConfirmationRecord {
  id                   String    @id @default(cuid())
  entityName           String
  category             String    // "Bank Balances and FDs" | "Borrowings" | "Trade Receivables" | "Trade Payables" | "Other Receivables" | "Other Payables"
  bankName             String?   // Bank Name / Confirming Party
  accountNumber        String?   // Bank/Loan Account Number (editable for Bank Balances/FDs and Borrowings)
  custId               String?   // Customer ID (editable for Bank Balances/FDs and Borrowings)
  emailTo              String    // Comma-separated email TO addresses
  emailCc              String?   // Comma-separated email CC addresses

  // Status tracking
  status               String    @default("not_sent") // not_sent | sent | followup_sent | response_received

  // Sent email details
  sentAt               DateTime?
  sentMessageId        String?   // Graph API message ID of sent confirmation
  sentEmailFilePath    String?   // Local file path of saved sent email HTML

  // Follow-up details (latest follow-up — kept for backward compat)
  followupSentAt       DateTime?
  followupMessageId    String?
  followupEmailFilePath String?

  // Follow-up history (all follow-ups, newest last)
  followupCount        Int       @default(0)
  followupsJson        String?   // JSON: [{sentAt, messageId, filePath, subject}]

  // Response details (first/latest response — kept for quick access)
  responseReceivedAt      DateTime?
  responseMessageId       String?
  responseSubject         String?
  responseBody            String?
  responseHtmlBody        String?
  responseFromEmail       String?
  responseFromName        String?
  responseEmailFilePath   String?  // Local file path of saved response HTML
  responseHasAttachments  Boolean  @default(false)
  responseAttachmentsJson String?  // JSON array: [{id, name, contentType, size}]

  // All responses (supports multiple replies in the same thread)
  responsesJson           String?  // JSON array: [{receivedAt, messageId, subject, fromEmail, fromName, htmlBody, body, filePath, hasAttachments, attachmentsJson}]

  // Attachment (Authority Letter)
  attachmentPath       String?   // Server path to uploaded attachment
  attachmentName       String?   // Original filename

  // Folder paths for navigating without app
  emailsSentFolderPath    String?  // Relative folder path: emails/{Entity}/{Category}/Emails Sent/
  responsesFolderPath     String?  // Relative folder path: emails/{Entity}/{Category}/Responses Received/

  // Query/Remarks
  remarks              String?

  userId               String
  emailConfigId        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("confirmation_records")
}

model AppSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  autoReplyCheck            Boolean  @default(true)   // Automatically check for replies on cron
  replyCheckIntervalMinutes Int      @default(30)      // How often to check for replies
  emailSaveBasePath         String   @default("emails") // Base folder path for saving emails
  /** Max number of ageing snapshot imports to keep (older imports + on-disk file removed) */
  snapshotRetentionCount    Int      @default(12)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("app_settings")
}

// —— Receivables / ageing (bulk email + tracker) —— //

model AgingImport {
  id                String   @id @default(cuid())
  userId            String
  fileName          String
  createdAt         DateTime @default(now())
  /** Relative path under CWD, e.g. uploads/snapshots/1700_name.xlsx */
  sourceFilePath    String?
  /** As-of/snapshot business date (from file or latest doc line) */
  snapshotDate      DateTime?
  /** JSON object: summed bucket label -> amount (portfolio totals) */
  bucketsJson       String?
  /** Distinct non-excluded customers in this import */
  customerCount     Int?
  /** All parsed rows (including excluded) for quick display */
  storedRowCount    Int?
  /** Denormalized: non-excluded, positive-balance line count in portfolio sense */
  openInvoiceCount  Int?
  /** Sum of line amounts (INR) for open receivables in this file */
  totalOutstandingAtImport Float?
  /** Previous `AgingImport` id when movement KPIs were calculated */
  comparedToImportId String?
  kpiGeneratedAt     DateTime?
  /** JSON: new/cleared, risk, period deltas — see `aging-snapshot-metrics` */
  metricsJson        String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems         AgingLineItem[]
  importAttachments AgingImportCustomerAttachment[]

  @@index([userId, createdAt])
  @@map("aging_imports")
}

model InvoiceChase {
  id                 String   @id @default(cuid())
  userId             String
  invoiceKey         String
  companyCode        String
  companyName        String
  customerCode       String
  customerName       String
  documentNo         String
  amountSnapshot     String?
  emailTo            String?
  emailCc            String?
  emailCount         Int      @default(0)
  followupCount      Int      @default(0)
  followupsJson      String?
  sentAt             DateTime?
  followupMessageId  String?
  sentMessageId      String?
  lastFollowupAt     DateTime?
  status             String   @default("outstanding")
  lastResponseAt     DateTime?
  responseMessageId  String?
  responseSubject    String?
  responsePreview    String?
  responsesJson         String?
  /** JSON: [{ "importId", "sentAt" }] one entry per import when a campaign (non-followup) send ran */
  outreachRoundsJson    String?
  lastImportId       String?
  emailConfigId      String?
  /** Set manually or by future NDR sync when a post-delivery bounce is recorded */
  bouncedAt          DateTime?
  bounceDetail       String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems          AgingLineItem[]

  @@unique([userId, invoiceKey])
  @@index([userId, status])
  @@map("invoice_chases")
}

model AgingLineItem {
  id                String   @id @default(cuid())
  importId          String
  userId            String
  invoiceChaseId    String?
  companyCode       String
  companyName       String
  customerCode      String
  customerName      String
  documentNo        String
  refNo             String?
  totalBalance      String?
  notDue            String?
  maxDaysBucket     String?
  docDate           DateTime?
  postingDate       DateTime?
  netDueDate        DateTime?
  generationMonth   String?
  emailTo           String
  emailCc           String
  customerNameKey   String
  excluded          Boolean  @default(false)
  rowIndex          Int
  import            AgingImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  invoiceChase      InvoiceChase? @relation(fields: [invoiceChaseId], references: [id], onDelete: SetNull)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([userId, importId])
  @@index([invoiceChaseId])
  @@map("aging_line_items")
}

model AgingAttachmentRule {
  id         String   @id @default(cuid())
  userId     String
  matchType  String
  matchValue String
  filePath   String
  fileName   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, matchType])
  @@map("aging_attachment_rules")
}

/** Per-invoice / per-customer file for a specific ageing import; preferred over global AgingAttachmentRule at send time. */
model AgingImportCustomerAttachment {
  id           String   @id @default(cuid())
  userId       String
  importId     String
  customerCode String
  customerName String
  filePath     String
  fileName     String
  mime         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  import       AgingImport  @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([importId, customerCode])
  @@index([userId, importId])
  @@map("aging_import_customer_attachments")
}

model CustomerEmailEntry {
  id          String   @id @default(cuid())
  userId      String
  keyType     String
  keyValue    String
  companyName String?
  emailTo     String
  emailCc     String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, keyType, keyValue])
  @@index([userId, keyType])
  @@map("customer_email_entries")
}

model ExcludedCustomer {
  id        String   @id @default(cuid())
  userId    String
  keyType   String // "customer_name" | "customer_code"
  keyValue  String
  reason    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, keyType, keyValue])
  @@index([userId, keyType])
  @@map("excluded_customers")
}
